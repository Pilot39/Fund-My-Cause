{
  "name": "graphql-api",
  "version": "1.0.0",
  "description": "GraphQL API server for Fund My Cause with contract data caching and real-time subscriptions",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:load": "artillery run load-test.yml",
    "test:load:report": "artillery run load-test.yml --output load-report.json && artillery report load-report.json",
    "test:load:smoke": "artillery run load-test-smoke.yml"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@apollo/server-plugin-inline-trace": "^4.10.0",
    "apollo-server-express": "^4.10.0",
    "graphql": "^16.8.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^5.14.0",
    "ws": "^8.14.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "redis": "^4.6.0",
    "dataloader": "^2.2.0",
    "@stellar/stellar-sdk": "14.6.1",
    "dotenv": "^16.0.0",
    "node-rate-limiter-flexible": "^2.4.1",
    "jsonwebtoken": "^9.1.0"
  },
  "devDependencies": {
    "artillery": "^2.0.0",
    "typescript": "^5.9.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.20",
    "@types/dataloader": "^2.0.2",
    "vitest": "^1.1.0",
    "tsx": "^4.6.0"
  }
}
