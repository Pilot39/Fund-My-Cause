{
  "name": "@fund-my-cause/monitoring-service",
  "version": "1.0.0",
  "description": "Comprehensive monitoring and incident response service for Fund My Cause",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -t fund-my-cause-monitoring-service:latest .",
    "docker:run": "docker run -p 9091:9091 -e NODE_ENV=production fund-my-cause-monitoring-service:latest"
  },
  "keywords": [
    "monitoring",
    "incident-response",
    "alerting",
    "pagerduty",
    "fund-my-cause"
  ],
  "author": "Fund My Cause Team",
  "license": "MIT",
  "dependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "axios": "^1.6.5",
    "express": "^4.18.2",
    "pagerduty-client": "^1.0.0",
    "prom-client": "^15.0.0",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^8.55.0",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
