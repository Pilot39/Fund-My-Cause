#!/usr/bin/env sh
. "$(dirname "$0")/_/husky.sh"

# Run lint-staged
npx lint-staged

# Secrets scanning: check staged files for common secret patterns
echo "Running secrets scan on staged files..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND=0
for FILE in $STAGED_FILES; do
  if [ -f "$FILE" ]; then
    # Skip binary files and known-safe files
    case "$FILE" in
      *.png|*.jpg|*.jpeg|*.gif|*.ico|*.woff*|*.ttf|*.eot|*.svg|*.lock|*.snap) continue ;;
      .gitleaks.toml|.secrets.baseline|.husky/*|docs/*|*.md) continue ;;
    esac

    if git show ":$FILE" | grep -qiE '(PRIVATE_KEY|SECRET_KEY|AWS_SECRET_ACCESS_KEY|ghp_[a-zA-Z0-9]{36}|password\s*=\s*["'"'"'][^"'"'"']{8,})' 2>/dev/null; then
      echo "⚠️  Potential secret detected in: $FILE"
      FOUND=1
    fi
  fi
done

if [ "$FOUND" = "1" ]; then
  echo ""
  echo "❌ Secrets scan failed. Potential secrets detected in staged files."
  echo "   Review the files above and remove any secrets before committing."
  echo "   To skip this check (for false positives), add the pattern to .gitleaks.toml allowlist."
  echo "   See docs/git-hooks.md for remediation steps."
  exit 1
fi

echo "✅ No secrets detected."
